{
  "name": "configuration-service",
  "version": "1.0.0",
  "description": "CLI-based configuration management service for platform teams",
  "main": "src/cli.js",
  "bin": {
    "config": "./src/cli.js"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "start": "node src/cli.js"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
